// ============================================================
// Brainwave EduSys - Prisma Schema
// Normalized MySQL database with 17 tables
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ============================================================
// Auth & Users
// ============================================================

model User {
  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid()) @db.VarChar(36)
  name           String    @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  phone          String?   @db.VarChar(20)
  whatsappNumber String?   @map("whatsapp_number") @db.VarChar(20)
  rollNumber     String?   @map("roll_number") @db.VarChar(50)
  department     String?   @db.VarChar(100)
  className      String?   @map("class_name") @db.VarChar(50)
  roleId         Int       @map("role_id")
  status         UserStatus @default(ACTIVE)
  metadata       Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  role              Role               @relation(fields: [roleId], references: [id])
  refreshTokens     RefreshToken[]
  userPermissions   UserPermission[]
  userGroups        UserGroup[]
  pushSubscriptions PushSubscription[]
  auditLogs         AuditLog[]         @relation("AuditUser")
  grantedPermissions UserPermission[]  @relation("GrantedBy")

  // Relations as creator/author
  createdGroups     Group[]            @relation("GroupCreator")
  addedToGroups     UserGroup[]        @relation("AddedBy")
  messageCampaigns  MessageCampaign[]
  importBatches     ImportBatch[]
  pushNotifications PushNotification[]

  // Message recipient
  messageRecipients MessageRecipient[]

  // Push notification recipient
  pushNotificationRecipients PushNotificationRecipient[]

  @@index([email])
  @@index([roleId])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(50)
  displayName String  @map("display_name") @db.VarChar(100)
  description String? @db.Text
  isSystem    Boolean @default(false) @map("is_system")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(100)
  displayName String  @map("display_name") @db.VarChar(200)
  module      String  @db.VarChar(50)
  description String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           Int     @id @default(autoincrement())
  userId       Int     @map("user_id")
  permissionId Int     @map("permission_id")
  granted      Boolean @default(true)
  grantedById  Int?    @map("granted_by")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy  User?      @relation("GrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  token      String    @unique @db.VarChar(512)
  expiresAt  DateTime  @map("expires_at")
  revoked    Boolean   @default(false)
  replacedBy String?   @map("replaced_by") @db.VarChar(512)
  userAgent  String?   @map("user_agent") @db.Text
  ipAddress  String?   @map("ip_address") @db.VarChar(45)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================================
// Groups
// ============================================================

model Group {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(255)
  slug        String      @unique @db.VarChar(255)
  description String?     @db.Text
  type        GroupType   @default(CUSTOM)
  status      GroupStatus @default(ACTIVE)
  createdById Int         @map("created_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  createdBy  User        @relation("GroupCreator", fields: [createdById], references: [id])
  userGroups UserGroup[]

  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("groups")
}

model UserGroup {
  id        Int @id @default(autoincrement())
  userId    Int @map("user_id")
  groupId   Int @map("group_id")
  addedById Int @map("added_by")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  addedBy User  @relation("AddedBy", fields: [addedById], references: [id])

  @@unique([userId, groupId])
  @@map("user_groups")
}

// ============================================================
// Messaging
// ============================================================

model MessageCampaign {
  id              Int             @id @default(autoincrement())
  uuid            String          @unique @default(uuid()) @db.VarChar(36)
  title           String?         @db.VarChar(255)
  messageBody     String          @map("message_body") @db.Text
  channel         MessageChannel
  recipientType   RecipientType   @map("recipient_type")
  status          CampaignStatus  @default(PENDING)
  totalRecipients Int             @default(0) @map("total_recipients")
  sentCount       Int             @default(0) @map("sent_count")
  failedCount     Int             @default(0) @map("failed_count")
  scheduledAt     DateTime?       @map("scheduled_at")
  startedAt       DateTime?       @map("started_at")
  completedAt     DateTime?       @map("completed_at")
  createdById     Int             @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  createdBy         User               @relation(fields: [createdById], references: [id])
  messageRecipients MessageRecipient[]
  messageLogs       MessageLog[]

  @@index([status])
  @@index([createdById])
  @@map("message_campaigns")
}

model MessageRecipient {
  id              Int                    @id @default(autoincrement())
  campaignId      Int                    @map("campaign_id")
  userId          Int                    @map("user_id")
  whatsappNumber  String?                @map("whatsapp_number") @db.VarChar(20)
  status          MessageRecipientStatus @default(PENDING)
  errorMessage    String?                @map("error_message") @db.Text
  sentAt          DateTime?              @map("sent_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  campaign    MessageCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id])
  messageLogs MessageLog[]

  @@index([campaignId])
  @@index([status])
  @@map("message_recipients")
}

model MessageLog {
  id                Int     @id @default(autoincrement())
  campaignId        Int     @map("campaign_id")
  recipientId       Int     @map("recipient_id")
  provider          String  @db.VarChar(50)
  providerMessageId String? @map("provider_message_id") @db.VarChar(255)
  status            String  @db.VarChar(50)
  requestPayload    Json?   @map("request_payload")
  responsePayload   Json?   @map("response_payload")
  error             String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  campaign  MessageCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipient MessageRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("message_logs")
}

// ============================================================
// Import
// ============================================================

model ImportBatch {
  id           Int          @id @default(autoincrement())
  uuid         String       @unique @default(uuid()) @db.VarChar(36)
  filename     String       @db.VarChar(255)
  fileType     ImportFileType @map("file_type")
  totalRows    Int          @default(0) @map("total_rows")
  successCount Int          @default(0) @map("success_count")
  skippedCount Int          @default(0) @map("skipped_count")
  failedCount  Int          @default(0) @map("failed_count")
  status       ImportStatus @default(PENDING)
  groupIds     Json?        @map("group_ids")
  errors       Json?
  createdById  Int          @map("created_by")

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  createdBy  User         @relation(fields: [createdById], references: [id])
  importRows ImportRow[]

  @@index([status])
  @@map("import_batches")
}

model ImportRow {
  id           Int             @id @default(autoincrement())
  batchId      Int             @map("batch_id")
  rowNumber    Int             @map("row_number")
  rawData      Json            @map("raw_data")
  status       ImportRowStatus
  errorMessage String?         @map("error_message") @db.Text
  userId       Int?            @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("import_rows")
}

// ============================================================
// Web Push
// ============================================================

model PushSubscription {
  id        Int     @id @default(autoincrement())
  userId    Int     @map("user_id")
  endpoint  String  @db.Text
  p256dh    String  @db.Text
  auth      String  @db.Text
  userAgent String? @map("user_agent") @db.Text
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user                       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushNotificationRecipients PushNotificationRecipient[]

  @@index([userId])
  @@index([isActive])
  @@map("push_subscriptions")
}

model PushNotification {
  id            Int           @id @default(autoincrement())
  title         String        @db.VarChar(255)
  body          String        @db.Text
  icon          String?       @db.VarChar(500)
  url           String?       @db.VarChar(500)
  data          Json?
  recipientType RecipientType @map("recipient_type")
  totalSent     Int           @default(0) @map("total_sent")
  totalFailed   Int           @default(0) @map("total_failed")
  createdById   Int           @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  createdBy  User                        @relation(fields: [createdById], references: [id])
  recipients PushNotificationRecipient[]

  @@map("push_notifications")
}

model PushNotificationRecipient {
  id              Int        @id @default(autoincrement())
  notificationId  Int        @map("notification_id")
  userId          Int        @map("user_id")
  subscriptionId  Int?       @map("subscription_id")
  status          PushStatus
  inAppRead       Boolean    @default(false) @map("in_app_read")
  pushRead        Boolean    @default(false) @map("push_read")
  errorMessage    String?    @map("error_message") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  notification PushNotification  @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id])
  subscription PushSubscription? @relation(fields: [subscriptionId], references: [id])

  @@index([notificationId])
  @@map("push_notification_recipients")
}

// ============================================================
// Audit / Changelog
// ============================================================

model AuditLog {
  id         BigInt  @id @default(autoincrement())
  userId     Int?    @map("user_id")
  action     String  @db.VarChar(100)
  module     String  @db.VarChar(50)
  targetType String? @map("target_type") @db.VarChar(50)
  targetId   Int?    @map("target_id")
  oldValues  Json?   @map("old_values")
  newValues  Json?   @map("new_values")
  ipAddress  String? @map("ip_address") @db.VarChar(45)
  userAgent  String? @map("user_agent") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation("AuditUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// Enums
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum GroupType {
  CLASS
  DEPARTMENT
  CUSTOM
}

enum GroupStatus {
  ACTIVE
  ARCHIVED
}

enum MessageChannel {
  WHATSAPP
  PUSH
  BOTH
}

enum RecipientType {
  SINGLE
  MULTIPLE
  GROUP
  ALL
}

enum CampaignStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  PARTIAL_FAILED
}

enum MessageRecipientStatus {
  PENDING
  SENT
  FAILED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ImportRowStatus {
  SUCCESS
  SKIPPED
  FAILED
}

enum ImportFileType {
  CSV
  XLSX
}

enum PushStatus {
  SENT
  FAILED
}
