{
  "name": "@brainwave/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "dotenv -e ../../.env.development -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "db:generate": "dotenv -e ../../.env.development -- prisma generate",
    "db:migrate": "dotenv -e ../../.env.development -- prisma migrate dev",
    "db:migrate:prod": "dotenv -e ../../.env.production -- prisma migrate deploy",
    "db:seed": "dotenv -e ../../.env.development -- prisma db seed",
    "db:studio": "dotenv -e ../../.env.development -- prisma studio",
    "db:push": "dotenv -e ../../.env.development -- prisma db push"
  },
  "dependencies": {
    "@brainwave/shared": "*",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.30.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mariadb": "^3.5.3",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "uuid": "^11.0.5",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
